{
  "name": "switch-board",
  "version": "0.4.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "description": "A calm command center for people operating across multiple ventures.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "tsx --test src/logic/**/*.test.ts app/api/**/*.test.ts",
    "benchmark:switch-cost": "tsx scripts/simulate-workday.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "postinstall": "sigmap",
    "map:refresh": "sigmap",
    "map:report": "sigmap --report --json",
    "map:watch": "sigmap daemon start",
    "map:setup": "sigmap --setup"
  },
  "dependencies": {
    "next": "^16.0.0",
    "openai": "^6.48.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/config": "^0.5.5",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "sigmap": "^8.18.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0"
  }
}
