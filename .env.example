NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only credentials for AI re-entry briefings. Keep real values in .env.local.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol

# Reserved for the persistence milestone.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
